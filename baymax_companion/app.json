{
  "expo": {
    "name": "Neuvix",
    "slug": "neuvix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./images/logoicon.png",
    "scheme": "baymaxcompanion",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.baymaxcompanion"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./images/logoicon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.anonymous.baymaxcompanion"
    },
    "web": {
      "output": "static",
      "favicon": "./images/logoicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./images/logoicon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "82598ec0-cbce-43db-8de9-79c9b7d277b2"
      }
    }
  }
}
